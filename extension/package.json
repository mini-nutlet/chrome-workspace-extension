{
  "name": "workspace-browser-companion-standalone",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build && npm run build:bg && npm run copy-manifest",
    "copy-manifest": "node -e \"require('fs').cpSync('public/manifest.json','dist/manifest.json')\"",
    "build:bg": "esbuild src/background/index.ts --bundle --format=esm --outfile=dist/background.js --target=es2022",
    "dev": "vite build --watch"
  },
  "dependencies": {
    "fuse.js": "^7.4.2",
    "idb": "^8.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.43",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0"
  }
}
